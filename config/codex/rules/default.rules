prefix_rule(pattern = ["git", "reset", "--hard"], decision = "forbidden")
prefix_rule(pattern = ["git", "branch", "-D"], decision = "forbidden")
prefix_rule(pattern = ["git", "checkout", "."], decision = "forbidden")
prefix_rule(pattern = ["git", "restore", "."], decision = "forbidden")
prefix_rule(pattern = ["git", "clean"], decision = "forbidden")
prefix_rule(pattern = ["gh", "repo", "delete"], decision = "forbidden")
prefix_rule(pattern = ["gh", "repo", "archive"], decision = "forbidden")
prefix_rule(pattern = ["gh", "pr", "close"], decision = "forbidden")
prefix_rule(pattern = ["gh", "pr", "merge"], decision = "forbidden")
prefix_rule(pattern = ["gh", "issue", "close"], decision = "forbidden")
prefix_rule(pattern = ["gh", "issue", "delete"], decision = "forbidden")
prefix_rule(pattern = ["gh", "release", "delete"], decision = "forbidden")
prefix_rule(pattern = ["git", "push"], decision = "prompt")
prefix_rule(pattern = ["gh", "api"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "apply"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "delete"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "patch"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "replace"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "scale"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "edit"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "annotate"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "label"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "cordon"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "uncordon"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "drain"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "taint"], decision = "prompt")
prefix_rule(pattern = ["kubectl", "rollout", "restart"], decision = "prompt")