{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent",
    "@franlol/opencode-md-table-formatter",
    "todo-continuation-enforcer",
    "opencode-roast-tone-plugin",
    "opencode-priority-rule-plugin"
  ],
  "model": "openai/gpt-5.4-fast",
  "small_model": "openai/gpt-5.3-codex-spark",
  "agent": {
    "build": {
      "model": "openai/gpt-5.3-codex-spark",
      "permission": {
        "skill": {
          "*": "deny",
          "git-commit-co-author": "allow"
        }
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": {
    "jdtls": {
      "command": [
        "/Users/samwang/dotfiles/bin/start_jdtls.sh"
      ],
      "extensions": [
        ".java"
      ]
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/code/github.com/**": "allow",
      "~/.agents/skills/**": "allow",
      "/tmp/**": "allow",
      "~/tmp/**": "allow"
    },
    "bash": {
      "git reset --hard *": "deny",
      "git clean -f*": "deny",
      "git branch -D *": "deny",
      "git checkout .": "deny",
      "git restore .": "deny",
      "gh repo delete *": "deny",
      "gh repo archive *": "deny",
      "gh pr close *": "deny",
      "gh pr merge *": "deny",
      "gh issue close *": "deny",
      "gh issue delete *": "deny",
      "gh release delete *": "deny",
      "gh api * -X DELETE": "deny",
      "gh api * --method DELETE": "deny",
      "git push *": "ask"
    }
  }
}