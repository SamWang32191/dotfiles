{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim",
    "@w32191/just-loop",
    "@franlol/opencode-md-table-formatter",
    "opencode-command-inject",
    "opencode-roast-tone-plugin",
    "opencode-priority-rule-plugin"
  ],
  "model": "openai/gpt-5.4-fast",
  "small_model": "openai/gpt-5.3-codex-spark",
  "agent": {
    "build": {
      "color": "primary"
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
  },
  "lsp": {
    "jdtls": {
      "command": [
        "/Users/samwang/dotfiles/bin/start_jdtls.sh"
      ],
      "extensions": [
        ".java"
      ]
    }
  }
}