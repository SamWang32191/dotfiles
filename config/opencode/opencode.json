{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@w32191/just-loop@latest",
    "@w32191/hashline-plugin@latest",
    "todo-continuation-enforcer@latest",
    "opencode-command-inject@latest"
  ],
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.3-codex-spark",
  "agent": {
    "build": {
      "permission": {
        "skill": {
          "*": "deny"
        }
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "lsp": {
      "jdtls": {
        "command": [
          "/Users/samwang/dotfiles/bin/start_jdtls.sh"
        ],
        "extensions": [
          ".java"
        ]
      }
    }
  }
}