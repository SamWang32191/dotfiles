{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "tui": {
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "small_model": "opencode/minimax-m2.1-free",
  "lsp": {
    "jdtls": {
      "command": [
        "/Users/samwang/dotfiles/bin/start_jdtls.sh"
      ],
      "extensions": [
        ".java"
      ]
    }
  },
  "provider": {
    "opencode": {
      "models": {
        "claude-sonnet-4-5": {
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "claude-opus-4-6": {
          "limit": {
            "context": 200000,
            "output": 64000
          }
        }
      }
    }
  }
}