{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-medium@latest",
    "@w32191/just-loop@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "agent": {
    "build": {
      "permission": {
        "skill": {
          "*": "deny"
        }
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "lsp": {
      "jdtls": {
        "command": [
          "/Users/samwang/dotfiles/bin/start_jdtls.sh"
        ],
        "extensions": [
          ".java"
        ]
      }
    }
  }
}