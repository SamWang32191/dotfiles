{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest",
    "opencode-antigravity-auth@latest"
  ],
  "tui": {
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "small_model": "opencode/minimax-m2.5-free",
